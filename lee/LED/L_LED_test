#왼쪽 방향지시등

import time
from pop import Pilot

# 1. 모터/LED 드라이버 설정 (I2C 1번 버스, 0x5c 주소)
LED = Pilot.PWM(1, 0x5c)
LED.setFreq(50)

# 깜빡이는 속도 조절 (초 단위)
# 예: 0.5초 동안 켜지고 0.5초 동안 꺼짐
blink_interval = 0.2 

# 테스트 진행 시간 (30초 동안 실행)
test_duration = 30

start_time = time.time()
print(f"왼쪽 방향지시등 깜빡이 테스트를 시작합니다. ({test_duration}초 동안)")

try:
    while time.time() - start_time < test_duration:
        
        # --- [STEP 1] 왼쪽 라인 LED ON ---
        # 확정된 핀 맵에 따라 홀수 채널(1, 3)을 왼쪽으로 설정
        LED.setDuty(1, 99)  # 앞쪽 왼쪽 ON
        LED.setDuty(3, 99)  # 뒤쪽 왼쪽 ON
        
        # 오른쪽 라인 및 나머지 채널은 모두 OFF 상태 유지
        LED.setDuty(0, 0)   # 앞쪽 오른쪽 OFF
        LED.setDuty(2, 0)   # 뒤쪽 오른쪽 OFF
        LED.setDuty(4, 0)
        LED.setDuty(5, 0)
        LED.setDuty(6, 0)
        LED.setDuty(7, 0)
        
        print("💡 왼쪽 방향지시등 ON")
        time.sleep(blink_interval)  # 설정한 시간만큼 켜짐 유지
        
        
        # --- [STEP 2] 모든 LED OFF ---
        for channel in range(8):
            LED.setDuty(channel, 0)
            
        print("⬛ 왼쪽 방향지시등 OFF")
        time.sleep(blink_interval)  # 설정한 시간만큼 꺼짐 유지

    print(f"{test_duration}초 테스트가 완료되었습니다.")

except Exception as e:
    print(f"⚠️ 제어 중 오류가 발생했습니다: {e}")

finally:
    # 테스트 종료 후 안전하게 모든 LED 소등
    print("안전을 위해 모든 LED를 소등합니다.")
    for channel in range(8):
        try:
            LED.setDuty(channel, 0)
        except:
            pass
