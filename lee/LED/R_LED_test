#오른쪽 방향지시등

import time
from pop import Pilot

# 1. 모터/LED 드라이버 설정 (I2C 1번 버스, 0x5c 주소)
LED = Pilot.PWM(1, 0x5c)
LED.setFreq(50)  # PWM 주파수 설정 (LED 제어에 적당한 속도)

# 테스트 진행 시간 설정 (초)
test_duration = 30
# 깜빡이는 주기 설정 (초 단위, 0.5초 켜고 0.5초 끄기 = 1초 한 주기)
blink_interval = 0.2

start_time = time.time()
print(f"오른쪽 방향지시등 깜빡이 테스트를 시작합니다. ({test_duration}초 동안)")

try:
    # 정해진 시간 동안 반복
    while time.time() - start_time < test_duration:
        
        # --- [STEP 1] 오른쪽 라인 LED ON ---
        # 이전 테스트 결과를 바탕으로 짝수 채널(0, 2)을 오른쪽으로 가정
        LED.setDuty(0, 99)  # 앞쪽 오른쪽 ON
        LED.setDuty(2, 99)  # 뒤쪽 오른쪽 ON
        
        # 나머지는 모두 OFF 상태 유지
        LED.setDuty(1, 0)   # 앞쪽 왼쪽 OFF
        LED.setDuty(3, 0)   # 뒤쪽 왼쪽 OFF
        LED.setDuty(4, 0)
        LED.setDuty(5, 0)
        LED.setDuty(6, 0)
        LED.setDuty(7, 0)
        
        print("💡 방향지시등 ON")
        time.sleep(blink_interval)  # 0.5초 동안 켜진 상태 유지
        
        
        # --- [STEP 2] 모든 LED OFF (비주기) ---
        for channel in range(8):
            LED.setDuty(channel, 0)
            
        print("⬛ 방향지시등 OFF")
        time.sleep(blink_interval)  # 0.5초 동안 꺼진 상태 유지

    print(f"{test_duration}초 테스트가 완료되었습니다.")

except Exception as e:
    print(f"⚠️ 제어 중 오류가 발생했습니다: {e}")

finally:
    # 테스트 종료 후 안전하게 모든 LED 소등
    print("안전을 위해 모든 LED를 소등합니다.")
    for channel in range(8):
        try:
            LED.setDuty(channel, 0)
        except:
            pass